# AI Provider: Choose from "gemini", "groq", "openrouter", or "openai"
AI_PROVIDER="gemini"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Required if AI_PROVIDER is "groq". Get one free at console.groq.com
GROQ_API_KEY="MY_GROQ_API_KEY"
GROQ_MODEL="llama-3.3-70b-versatile"

# OPENROUTER_API_KEY: Required if AI_PROVIDER is "openrouter". Get one at openrouter.ai
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"
OPENROUTER_MODEL="meta-llama/llama-3-8b-instruct:free"

# OPENAI_API_KEY: Required if AI_PROVIDER is "openai".
OPENAI_API_KEY="MY_OPENAI_API_KEY"
OPENAI_MODEL="gpt-4o-mini"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

